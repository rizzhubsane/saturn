# ── Meta WhatsApp Cloud API ──
WHATSAPP_PHONE_NUMBER_ID=        # From Meta Business Manager → Phone Numbers
WHATSAPP_BUSINESS_ACCOUNT_ID=    # From Meta Business Manager → Business Settings
WHATSAPP_ACCESS_TOKEN=           # Permanent system user token from Meta
WHATSAPP_VERIFY_TOKEN=           # Custom string you create for webhook verification
WHATSAPP_APP_SECRET=             # App Secret from Meta App Dashboard → Settings → Basic
WHATSAPP_COMMUNITY_GROUP_ID=     # WhatsApp Community announcement group JID (optional)

# ── OpenRouter ──
OPENROUTER_API_KEY=              # From openrouter.ai/keys
OPENROUTER_MODEL=google/gemini-2.5-flash  # Model identifier

# ── Supabase ──
SUPABASE_URL=https://jnyurhdmuifmozuqdors.supabase.co
SUPABASE_ANON_KEY=               # Project → Settings → API → anon/public key
SUPABASE_SERVICE_ROLE_KEY=       # Project → Settings → API → service_role key (keep secret!)

# ── App Config ──
PORT=3000
NODE_ENV=development
TIMEZONE=Asia/Kolkata
GOD_PHONE=+91XXXXXXXXXX         # Your phone number in E.164 format
# false (default): reply-only DMs; god /broadcast and promote welcome DM need true. No scheduled WhatsApp digests (removed).
ALLOW_PROACTIVE_OUTBOUND=false
# HTTPS URL of this API (no trailing slash) — required for Apple Calendar .ics links in /remind flow
PUBLIC_BASE_URL=
